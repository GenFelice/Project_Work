{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/copyright",
	"version": "0.1.0",
	"title": "Copyright",
	"category": "widgets",
	"description": "Display your site\\’s copyright date.",
	"example": {},
	"supports": {
		"color": {
			"background": false,
			"text": true
		},
		"html": false,
		"typography": {
			"fontSize": true,
			"textAlign": true
		}
	},
	"textdomain": "copyright",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"attributes": {
		"prefix": { "type": "string" },
		"suffix": { "type": "string" },
		"startingYear": { "type": "string" },
		"showStartingYear": { "type": "boolean", "default": false }
	}
	
}
